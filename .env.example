# Database (Drizzle — use `pnpm db:push` or `pnpm db:migrate`, not Prisma)
# Neon’s UI may append channel_binding=require; the app strips it for postgres.js compatibility.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# App (use your real browser URL in production, e.g. https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Comma-separated emails that are auto-approved and can open Settings → User approvals (bootstrap admins).
# Other users register as pending until an app admin approves them.
# Put this in repo-root `.env.local` or `apps/web/.env.local` (both are loaded by Next).
# CRM_ADMIN_EMAILS=you@yourcompany.com

# Better Auth: comma-separated full origins (optional)
# TRUSTED_ORIGINS=https://openclaw-crm-web.vercel.app

# Comma-separated hostnames only (no https://) — use when you use a custom domain
# but VERCEL_PROJECT_PRODUCTION_URL still points at *.vercel.app
# AUTH_TRUSTED_HOSTS=darioushkottke.online,www.darioushkottke.online

# Feature flag — surfaces the Sales-Outreach-Agent draft suggestion banner
# above the inbox composer when an unconsumed `Antwort-Entwurf · Sales Outreach
# Agent` note exists on the deal. Set to `true` once a draft-producing routine
# is wired up; default off.
NEXT_PUBLIC_ENABLE_AGENT_DRAFT_BANNER=false

# OAuth (optional - leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional - for transactional emails)
RESEND_API_KEY=

# Messaging — outbound SMS for the post-move reviews engine (KOT-617).
# Provider switch lets us swap to e.g. Twilio later without touching the
# cron job. Spend is billed under the Reviews Engine line of KOT-591.
# MESSAGING_PROVIDER=messagebird
# MESSAGEBIRD_API_KEY=
# MESSAGEBIRD_ORIGINATOR=Kottke
# MessageBird inbound webhook signing key — set when the inbound route lands
# (separate PR). Validates `messagebird-signature-jwt` on POSTs.
# MESSAGEBIRD_SIGNING_KEY=

# Reviews engine — per-brand Google Business Profile review URLs (KOT-616).
# REVIEWS_GBP_URL_KOTTKE=https://g.page/r/<kottke-gbp-id>/review
# REVIEWS_GBP_URL_CEYLAN=https://g.page/r/<ceylan-gbp-id>/review

# Financial database (separate Neon instance for Ausgaben / Zahlungen / Mitarbeiter-Konten)
FINANCIAL_DATABASE_URL=postgresql://user:password@host/financial_db?sslmode=require

# Inbox — Gmail IMAP/SMTP per operating-company email account
# Add one block per email account; increment the number (EMAIL_1, EMAIL_2, …)
# PASSWORD must be a Gmail App Password (not your Google login password)
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
# EMAIL_1_ADDRESS=kottkeumzuege@gmail.com
# EMAIL_1_PASSWORD=your-gmail-app-password
# EMAIL_2_ADDRESS=ceylanoperations@gmail.com
# EMAIL_2_PASSWORD=your-gmail-app-password

# Docker Compose production (optional - used by docker-compose.prod.yml)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=openclaw
# APP_PORT=3000

# ─── Web Push (iOS / Android / Desktop home-screen PWA) ─────────────────
# Generate once with:
#   pnpm --filter @openclaw-crm/web push:generate-keys
# Then paste the three values below. NEXT_PUBLIC_VAPID_PUBLIC_KEY MUST equal
# VAPID_PUBLIC_KEY — the public copy is bundled so the client can subscribe.
# Without these set, the app still works; push notifications are simply
# disabled and the toggle in Settings shows a "not configured" hint.
# VAPID_PUBLIC_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@kottke-umzuege.de

# ─── Google Maps (server-side) ─────────────────────────────────────────
# Enable BOTH APIs in Google Cloud Console:
#   - Distance Matrix API     (used by Auftrag time estimate)
#   - Street View Static API  (used by Auftragsanweisung + price calculator thumbnails)
# Restrict the key in Cloud Console to those two APIs only.
GOOGLE_MAPS_API_KEY=
