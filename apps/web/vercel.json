{
  "buildCommand": "cd ../.. && npx turbo build --filter=@openclaw-crm/web --env-mode=loose",
  "installCommand": "cd ../.. && pnpm install",
  "crons": [
    {
      "path": "/api/cron/inbox-sync",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/immoscout-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/refresh-leads-insights",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/check-overdue-tasks",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/reviews-send",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/agent-replies",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/agent-followups",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/agent-classify",
      "schedule": "*/5 * * * *"
    }
  ]
}
